# ── Copy this file to .env and fill in real values ─────────────────────────
# Never commit .env to version control.

# ── Postgres ─────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=change_me_postgres_password

# ── MinIO (S3-compatible storage) ────────────────────────────────────────────
MINIO_ACCESS_KEY=zoora_minio_user
MINIO_SECRET_KEY=change_me_minio_password

# ── n8n ──────────────────────────────────────────────────────────────────────
N8N_USER=admin
N8N_PASSWORD=change_me_n8n_password
N8N_ENCRYPTION_KEY=change_me_32_char_encryption_key_here

# ── Backend API ───────────────────────────────────────────────────────────────
# Must be a long, random secret (openssl rand -base64 64)
JWT_SECRET=change_me_jwt_secret_very_long_random_string

# Service API key — only the scoring engine / n8n use this to write to scores
# Must be kept out of the frontend
SERVICE_API_KEY=change_me_service_api_key

# ── Anthropic (Claude) ────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...your-key-here...
